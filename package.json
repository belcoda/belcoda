{
	"name": "belcoda",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"app:dev": "vite dev | pino-pretty -c -t",
		"app:dev:force": "vite dev --force",
		"dev": "npx concurrently -p \"[{name}]\" -n \"APP,ZERO\" -c \"bgMagenta.bold,bgBlue.bold\"  \"vite dev | pino-pretty -c -t\"  \"npm run zero:dev\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"generate": "svelte-kit sync && drizzle-zero generate --format --output ./src/lib/zero/zero-schema.gen.ts --config ./src/lib/zero/drizzle-zero.config.ts --drizzle-kit-config ./drizzle.config.ts",
		"ngrok": "node ngrok.config.cjs",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"db:push": "drizzle-kit push",
		"db:deleteall": "npx vite-node --options.transformMode.ssr='/.*/' src/lib/server/db/seed/reset.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:reset": "npm run db:deleteall && npm run db:push && npm run db:seed && npm run generate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "npx vite-node --options.transformMode.ssr='/.*/' src/lib/server/db/seed/index.ts",
		"wuchale:extract": "wuchale --config wuchale.config.ts",
		"wuchale:clean": "wuchale --config wuchale.config.ts --clean",
		"zero:dev": "npx zero-cache-dev --schema-path=./src/lib/z/schema.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^9.39.1",
		"@faker-js/faker": "^10.1.0",
		"@iconify-json/lucide": "^1.2.75",
		"@iconify/json": "^2.2.410",
		"@iconify/tailwind4": "^1.1.0",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.56.1",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.49.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24",
		"@types/papaparse": "^5.5.2",
		"@vitest/browser": "^4.0.14",
		"@vitest/browser-playwright": "^4.0.14",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.7",
		"drizzle-orm": "^0.44.7",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.0",
		"formsnap": "^2.0.1",
		"globals": "^16.5.0",
		"mode-watcher": "^1.1.0",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.2",
		"playwright": "^1.56.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.43.14",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.6",
		"sveltekit-superforms": "^2.28.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.47.0",
		"uuid": "^13.0.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.2.4",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.14",
		"vitest-browser-svelte": "^2.0.1"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.948.0",
		"@aws-sdk/s3-request-presigner": "^3.948.0",
		"@better-auth/stripe": "^1.4.4",
		"@rocicorp/zero": "^0.24.3000000000",
		"@scalar/sveltekit": "^0.1.29",
		"@types/country-list": "^2.1.4",
		"@sentry/sveltekit": "^10.37.0",
		"@wuchale/svelte": "^0.17.5",
		"@wuchale/vite-plugin": "^0.15.3",
		"awesome-phonenumber": "^7.6.0",
		"better-auth": "^1.4.1",
		"country-list": "^2.4.1",
		"drizzle-seed": "^0.3.1",
		"drizzle-valibot": "^0.4.2",
		"drizzle-zero": "^0.16.2",
		"fast-csv": "^5.0.5",
		"fuse.js": "^7.1.0",
		"javascript-time-ago": "^2.5.12",
		"jwt-decode": "^4.0.0",
		"lru-cache": "^11.2.2",
		"melt": "^0.42.0",
		"nanoid": "^5.1.6",
		"papaparse": "^5.5.3",
		"pg-boss": "^12.5.4",
		"postgres": "^3.4.7",
		"qr": "^0.5.3",
		"stripe": "^20.0.0",
		"svelte-easy-crop": "^5.0.0",
		"svelte-lexical": "^0.6.3",
		"svelte-multiselect": "^11.6.0",
		"valibot": "^1.1.0",
		"wuchale": "^0.18.5",
		"zero-svelte": "^1.1.2"
	}
}
